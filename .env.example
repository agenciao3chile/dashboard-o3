# ─── Base de datos ──────────────────────────────────────────────────────
# En PRODUCCIÓN: cadena de conexión al Postgres del agente.
# Ej: postgres://o3_dashboard_ro:CLAVE@apps_db-agenteo3:5432/apps
# OJO: si la clave tiene caracteres especiales (@ : / # ?) hay que URL-encodearlos.
# Si se deja VACÍO, el dashboard arranca en MODO DEMO con datos sintéticos
# (Postgres embebido con pglite) — ideal para probar sin tocar la base real.
DATABASE_URL=

# Alternativa recomendada: variables sueltas (node-postgres las lee solas). Evitan
# el URL-encoding y permiten copiar tal cual las credenciales del agente. Si
# definís PGHOST/PGDATABASE, el panel entra en modo producción (ignora DATABASE_URL vacía).
#   PGHOST=apps_db-agenteo3
#   PGPORT=5432
#   PGUSER=postgres
#   PGPASSWORD=la-clave-tal-cual
#   PGDATABASE=apps

# Zona horaria para los cálculos de fecha (América/Santiago por defecto).
TZ=America/Santiago

# Puerto del servidor (Fastify). En EasyPanel exponé este puerto.
PORT=3001

# ─── Acceso (opcional) ──────────────────────────────────────────────────
# Si se define, el dashboard pide esta clave (una sola, compartida por
# dirección) antes de mostrar nada. Vacío = sin login (solo para pruebas).
DASHBOARD_PASSWORD=

# ─── Insights con LLM (opcional) ────────────────────────────────────────
# Si se define, los insights en lenguaje natural se pulen con el LLM.
# Vacío = insights por reglas (igual funcionan, sin costo).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
